<!-- Vas a recibir un listado múltiple (IEnumerable) de objetos tipo Persona -->
@model IEnumerable<MiCrudWeb.Models.Persona>

@{
    ViewData["Title"] = "Página de Inicio";
}

<!-- Aviso flotante de éxito al guardar  -->
@if (TempData["MensajeAccion"] != null)
{
    <div class="alert alert-success text-center mt-3 fs-5 font-weight-bold" role="alert">
        @TempData["MensajeAccion"]
    </div>
}

<div class="container mt-2">
    <div class="text-center">
        <h1 class="display-6 font-weight-bold text-dark">Panel de Gestión General  DRAMAZOOOCLS</h1>
    </div>
    <!-- Botón para ir al formulario de ingreso -->
    <div class="mt-2 mb-1">
        <a asp-controller="Home" asp-action="Crear" class="btn btn-primary btn-lg font-weight-bold shadow-sm">
            Registrar Nueva Persona
        </a>
    </div>


    <!--  tabla -->
    <div class="card shadow-sm border rounded bg-white p-4">
        <!-- activar el scroll vertical automático -->
        <div style="max-height: 280px; overflow-y: auto;" class="border rounded">
            <!-- Agregamos la propiedad 'table-responsive' de Bootstrap -->
            <table class="table table-bordered table-striped table-hover align-middle m-0">
                <!-- Nota: Para congelar el techo de la tabla al hacer scroll, agregamos 'sticky-top' -->
                <thead class="table-dark sticky-top">
                    <tr>
                        <th style="width: 20%;">RUN Chileno</th>
                        <th style="width: 40%;">Nombre Completo</th>
                        <th style="width: 15%;" class="text-center">Edad</th>
                        <th style="width: 25%;" class="text-center">Acciones</th>
                    </tr>
                </thead>

                <!--  inyectan los datos reales -->
                <tbody>
                    <!-- Verificar si la base de datos está vacía -->
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted p-4 fs-5">
                                No existen personas registradas en la base de datos actualmente.
                            </td>
                        </tr>
                    }
                    else
                    {
                        // por cada persona que encuentre, fabricará de forma automática una fila <tr> en la web
                        foreach (var persona in Model)
                        {
                            <tr>
                                <td class="font-weight-bold text-primary">@persona.RUN</td>
                                <td>@persona.Nombre</td>
                                <td class="text-center">@persona.Edad años</td>

                                <!-- BOTONES DE LAS ACCIONES -->
                                <td class="text-center">
                                    <!-- Botón Editar Amarillo -->
                                    <!-- 'asp-route-id' le pasa el RUN a la cocina de C# de forma invisible -->
                                    <a asp-controller="Home" asp-action="Editar" asp-route-id="@persona.RUN"
                                       class="btn btn-warning btn-sm font-weight-bold me-1">
                                        Editar
                                    </a>

                                    <!-- Botón Eliminar Rojo -->
                                    <a asp-controller="Home" asp-action="Eliminar" asp-route-id="@persona.RUN"
                                       class="btn btn-danger btn-sm font-weight-bold">
                                        Eliminar
                                    </a>
                                </td>


                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Barra de Estado Profesional con Contador -->
    <div class="alert alert-secondary text-center mt-4 p-2 small font-weight-bold" role="alert">
        @ViewData["TotalRegistrados"]
    </div>

</div>
