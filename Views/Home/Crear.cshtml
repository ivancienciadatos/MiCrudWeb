@model MiCrudWeb.Models.Persona

@{
    ViewData["Title"] = "Registrar ";
}

<div class="container mt-5" style="max-width: 500px;">
    <h2 class="text-center text-primary mb-4">Registrar Persona</h2>


    <!--mensaje del controlador y dibuja el banner verde aquí mismo si existe -->
    @if (ViewData["MensajeExito"] != null)
    {
        <div class="alert alert-success text-center mb-3 small font-weight-bold" role="alert">
            @ViewData["MensajeExito"]
        </div>
    }


    <!-- avisa al navegador que mandará los datos al controlador Home y a la función Crear -->
    <form asp-controller="Home" asp-action="Crear" method="post" class="border p-4 shadow-sm rounded bg-white">

        <!--  RUN -->
        <div class="mb-3">
            <label asp-for="RUN" class="form-label font-weight-bold">RUN Chileno:</label>
            <input asp-for="RUN" class="form-control" placeholder="12345678-K" />
            <span asp-validation-for="RUN" class="text-danger small"></span>
        </div>

        <!--  Nombre -->
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label font-weight-bold">Nombre Completo:</label>
            <input asp-for="Nombre" class="form-control" placeholder="Juan Pérez" />
            <span asp-validation-for="Nombre" class="text-danger small"></span>
        </div>

        <!--  Edad -->
        <div class="mb-3">
            <label asp-for="Edad" class="form-label font-weight-bold">Edad:</label>
            <input asp-for="Edad" class="form-control" type="number" />
            <span asp-validation-for="Edad" class="text-danger small"></span>
        </div>

        <!-- Boton -->
        <div class="d-grid gap-2 mt-4">
            <button type="submit" class="btn btn-success font-weight-bold">Guardar en Base de Datos</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al Inicio</a>
        </div>
    </form>
</div>


<!-- bloque javascript -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        
        // Buscar el cuadro de texto del RUN y la etiqueta roja de error
        const inputRun = document.querySelector('input[name="RUN"]');
        // Buscar el elemento span encargado de pintar el error del RUN en la pantalla
        const errorRunSpan = document.querySelector('[data-valmsg-for="RUN"]');

        // Si existen ambos elementos en la pantalla (
        if (inputRun && errorRunSpan) {
            // Escuchamos activamente cuando el usuario teclee dentro de la casilla del RUN
            inputRun.addEventListener('input', function() {
                // Borramos el texto del error por completo para limpiar la pantalla
                errorRunSpan.textContent = '';
            });
        }

        // Mantener el borrador del banner verde 
        const bannerExito = document.querySelector('.alert-success');
        if (bannerExito) {
            const casillasTexto = document.querySelectorAll('.form-control');
            casillasTexto.forEach(casilla => {
                casilla.addEventListener('input', function() {
                    bannerExito.style.display = 'none';
                });
                casilla.addEventListener('focus', function() {
                    bannerExito.style.display = 'none';
                });
            });
        }
    });
</script>
